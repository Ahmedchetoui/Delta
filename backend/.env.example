# ===========================================
# Delta Fashion — Backend (Render production)
# ===========================================
# Copiez ces variables dans Render → Environment

NODE_ENV=production
PORT=10000
HOST=0.0.0.0

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/delta-fashion

# Sécurité
JWT_SECRET=generer-une-cle-longue-et-aleatoire

# URL publique du backend Render (sans slash final)
PUBLIC_BASE_URL=https://delta-n5d8.onrender.com

# CORS — URL(s) Vercel du frontend (séparées par des virgules)
CORS_ORIGIN=https://delta-fashion.vercel.app,https://delta-e79s.vercel.app,https://delta-fashion-e-commerce.vercel.app

# ===========================================
# Cloudinary (OBLIGATOIRE sur Render)
# ===========================================
# Dashboard Cloudinary → Account Details → API Keys
# Format URL (recommandé sur Render) :
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# OU variables séparées :
# CLOUDINARY_CLOUD_NAME=votre_cloud_name
# CLOUDINARY_API_KEY=votre_api_key
# CLOUDINARY_API_SECRET=votre_api_secret

# Dossier de stockage dans Cloudinary
CLOUDINARY_FOLDER=delta-fashion/uploads

# Optionnel — route /api/seed-database (toujours protégée par secret)
SEED_SECRET=secret-pour-route-seed
SEED_ADMIN_EMAIL=admin@deltafashion.com
SEED_ADMIN_PASSWORD=changer-ce-mot-de-passe
SEED_AHMED_EMAIL=ahmed@example.com
SEED_AHMED_PASSWORD=changer-ce-mot-de-passe

# ===========================================
# File d'attente commandes (P2 — optionnel)
# ===========================================
# Redis managé (ex. Upstash gratuit) — active BullMQ en production
# REDIS_URL=rediss://default:PASSWORD@HOST:6379

# Concurrence de traitement des commandes (défaut: 3)
# ORDER_QUEUE_CONCURRENCY=3

# Pool connexions MongoDB (défaut: 50)
# MONGODB_MAX_POOL_SIZE=50
